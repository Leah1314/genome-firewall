# Copy this file to .env and fill in your key. .env is gitignored -- never commit it.

# Required to enable the optional Report Agent (src/openai-report.js) and
# Evidence Diagram Agent (src/openai-image.js). Without it both stay off and
# the rest of the app works exactly as before.
OPENAI_API_KEY=

# Optional overrides, defaults shown.
# OPENAI_MODEL=gpt-5.4-mini
# OPENAI_IMAGE_MODEL=gpt-image-2
